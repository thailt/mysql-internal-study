[mysqld]
# Buffer Pool - observable for Phase 2
innodb_buffer_pool_size = 256M
innodb_buffer_pool_instances = 1

# Logging - observable for Phase 2 & 4
innodb_flush_log_at_trx_commit = 1
slow_query_log = ON
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 1

# General log for tracing query flow (Phase 1)
general_log = ON
general_log_file = /var/lib/mysql/general.log

# Binary log for Phase 4
log_bin = mysql-bin
server_id = 1
binlog_format = ROW
